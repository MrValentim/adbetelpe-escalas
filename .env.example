# ────────────────────────────────────────────────────
# ADBETELPE — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NÃO suba o .env.local para o GitHub
# ────────────────────────────────────────────────────

# Supabase — encontre em: https://app.supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Supabase Service Role (apenas no servidor, nunca exposta ao browser)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# URL do sistema em produção (para links nos e-mails)
NEXT_PUBLIC_APP_URL=https://escalas.adbetelpe.com.br

# Resend — envio de e-mails (https://resend.com)
RESEND_API_KEY=re_sua_chave_aqui
RESEND_FROM_EMAIL=noreply@adbetelpe.com.br
